{
    "name": "mizan-checker",
    "version": "1.1.0",
    "description": "Validate and verify Quranic verses in LLM-generated text. Catches hallucinated verses, misquoted references, and fabricated Arabic that LLMs confidently invent.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "data"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "fetch-quran": "tsx scripts/fetch-quran-data.ts"
    },
    "keywords": [
        "quran",
        "islamic",
        "validation",
        "llm",
        "arabic",
        "text-verification",
        "ai",
        "nlp"
    ],
    "author": "azrirefik",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/azrirefik/mizan-checker.git"
    },
    "bugs": {
        "url": "https://github.com/azrirefik/mizan-checker/issues"
    },
    "homepage": "https://github.com/azrirefik/mizan-checker#readme",
    "dependencies": {
        "arabic-text-normalizer": "^1.3.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "tsup": "^8.0.1",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vitest": "^1.2.0"
    },
    "engines": {
        "node": ">=18"
    }
}